<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:a="https://sunce.tech/aura3d"
            xmlns:acr="clr-namespace:Aura3D.Core.Renderers;assembly=Aura3D.Core"
             x:Class="Example.Pages.CelShadingPage">
    <a:Aura3DView x:TypeArguments="acr:CelShadingPipeline" x:Name="aura3Dview" SceneInitialized="Aura3DView_SceneInitialized" SceneUpdated="Aura3DView_SceneUpdated"></a:Aura3DView>
</UserControl>
